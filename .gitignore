# ============================================================
#  .gitignore — Médiathèque
# ============================================================

# Secrets
.env

# Dépendances
/src/vendor/
/src/node_modules/

# Données Docker persistantes (ne pas versionner)
/mysql_data/

# Images générées / uploadées
/src/public/images/posters/*
/src/public/images/backdrops/*
/src/public/images/thumbnails/*
/src/public/images/episodes/*
!/src/public/images/**/.gitkeep

# Logs
*.log
/logs/

# OS
.DS_Store
Thumbs.db
desktop.ini

# IDE
.idea/
.vscode/
*.swp
*.swo
