# ============================================================
#  HOSHIMI (星見) — Template des variables d'environnement
#  Copiez ce fichier en .env et remplissez les valeurs
# ============================================================

# --- Application ---
APP_NAME=Hoshimi
APP_ENV=development
APP_URL=http://localhost:8080
APP_DEBUG=true

# --- APIs externes ---
ANILIST_API_URL=https://graphql.anilist.co
ANIDB_CLIENT=votre_client_anidb
ANIDB_CLIENTVER=1

# --- Stockage des médias ---
ANIMES_PATH=/media/animes
IMAGES_PATH=/var/www/html/public/images

# --- phpMyAdmin ---
PMA_HOST=mysql
PMA_PORT=3306