# ============================================================
#  HOSHIMI (星見) — Template des variables d'environnement
#  Copiez ce fichier en .env et remplissez les valeurs
# ============================================================

# --- Application ---
APP_NAME=Hoshimi
APP_ENV=development
APP_URL=http://localhost:8080
APP_DEBUG=true

# --- APIs externes ---
ANILIST_API_URL=https://graphql.anilist.co

# --- Stockage des médias ---
ANIMES_PATH=/media/animes
FILMS_PATH=/media/films
SERIES_PATH=/media/series
IMAGES_PATH=/var/www/html/public/images

# --- Chemins hôte Windows (utilisés par les scripts CLI) ---
# Doit pointer vers un lecteur partagé dans Docker Desktop (Settings > File Sharing)
ANIMES_HOST_PATH=Y:\Animes
FILMS_HOST_PATH=Y:\Films
SERIES_HOST_PATH=Y:\Series